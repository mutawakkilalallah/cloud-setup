#!/bin/bash
set -e

DOMAIN="ollama.tiarinadev.my.id"
EMAIL="admin@tiarinadev.my.id"

MODEL_DISK="/dev/nvme1n1"
MODEL_DIR="/mnt/models"
SWAP_SIZE="16G"

echo "=== Update system ==="
sudo apt update
sudo apt upgrade -y

echo "=== Install NVIDIA driver ==="
sudo ubuntu-drivers install || true

echo "=== Install packages ==="
sudo apt install -y \
  curl \
  wget \
  git \
  jq \
  nginx \
  ufw \
  nvtop \
  fastfetch \
  nvidia-cuda-toolkit \
  certbot \
  python3-certbot-nginx

echo "=== Setup local NVMe for Ollama models ==="
if [ -b "$MODEL_DISK" ]; then
  if ! mount | grep -q "$MODEL_DIR"; then
    sudo mkfs.ext4 -F "$MODEL_DISK"
    sudo mkdir -p "$MODEL_DIR"
    sudo mount "$MODEL_DISK" "$MODEL_DIR"

    UUID=$(sudo blkid -s UUID -o value "$MODEL_DISK")

    if ! grep -q "$UUID" /etc/fstab; then
      echo "UUID=$UUID $MODEL_DIR ext4 defaults,nofail 0 2" | sudo tee -a /etc/fstab
    fi
  fi
else
  echo "WARNING: $MODEL_DISK not found, skipping model disk setup"
fi

echo "=== Create swap ${SWAP_SIZE} ==="
if [ ! -f /swapfile ]; then
  sudo fallocate -l "$SWAP_SIZE" /swapfile
  sudo chmod 600 /swapfile
  sudo mkswap /swapfile
  sudo swapon /swapfile

  if ! grep -q "/swapfile" /etc/fstab; then
    echo "/swapfile none swap sw 0 0" | sudo tee -a /etc/fstab
  fi
fi

echo "=== Install Ollama ==="
curl -fsSL https://ollama.com/install.sh | sh

echo "=== Configure Ollama ==="
sudo mkdir -p "$MODEL_DIR/ollama"
sudo chown -R ollama:ollama "$MODEL_DIR/ollama"

sudo mkdir -p /etc/systemd/system/ollama.service.d

sudo tee /etc/systemd/system/ollama.service.d/override.conf > /dev/null <<EOF
[Service]
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=$MODEL_DIR/ollama"
EOF

sudo systemctl daemon-reload
sudo systemctl enable ollama
sudo systemctl restart ollama

echo "=== Configure Nginx: tiarinadev ==="
sudo tee /etc/nginx/sites-available/tiarinadev > /dev/null <<EOF
server {
    listen 80;
    server_name ${DOMAIN};

    location / {
        proxy_pass http://localhost:11434;

        proxy_http_version 1.1;
        proxy_set_header Host localhost;
        proxy_set_header Origin "";

        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
EOF

sudo ln -sf /etc/nginx/sites-available/tiarinadev /etc/nginx/sites-enabled/tiarinadev
sudo rm -f /etc/nginx/sites-enabled/default

sudo nginx -t
sudo systemctl restart nginx

echo "=== Open firewall ==="
sudo ufw allow OpenSSH || true
sudo ufw allow 'Nginx Full' || true

echo "=== Install SSL with Certbot ==="
sudo certbot --nginx \
  -d "$DOMAIN" \
  --non-interactive \
  --agree-tos \
  -m "$EMAIL" \
  --redirect || true

echo "=== Re-apply Nginx proxy config after Certbot ==="
sudo nginx -t
sudo systemctl reload nginx

echo "=== Status ==="
df -h
free -h
fastfetch || true
nvcc --version || true
nvidia-smi || echo "NVIDIA driver installed, reboot likely required."

echo "=== Test endpoints ==="
curl -s "http://localhost:11434/v1/models" | jq || true
curl -s "https://${DOMAIN}/v1/models" | jq || true

echo "=== Done ==="
echo "Base URL: https://${DOMAIN}"
echo "Models endpoint: https://${DOMAIN}/v1/models"
echo ""
echo "IMPORTANT:"
echo "1. Pastikan Cloudflare DNS untuk domain ini mode DNS only, bukan proxied."
echo "2. Reboot sekali setelah script selesai:"
echo "   sudo reboot"
echo ""
echo "After reboot:"
echo "nvidia-smi"
echo "ollama pull qwen3:32b"
